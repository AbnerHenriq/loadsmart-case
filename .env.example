# Copy to a local file (not versioned):  cp .env.example .env
# Docker Compose reads `.env` for Airflow and Superset (see docker-compose.yml).

# PostgreSQL — must match the `postgres_meta` service in docker-compose.yml
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Airflow — Fernet key must be a valid Fernet string (generate a new one for production):
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=iErxHXcWPzEQZS2Afxyre7NRvu4LnLDFyZgQ7VEikis=
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-local-dev

# Superset — consumed by docker/superset/superset_config.py as Flask SECRET_KEY
SUPERSET_SECRET_KEY=change-me-local-dev

# Optional — monthly CSV email (export_last_month). If any of these are missing or empty,
# the pipeline still writes data/exports/deliveries_YYYY_MM.csv but does not send email.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password-here
# SMTP_RECIPIENTS=recipient@example.com
